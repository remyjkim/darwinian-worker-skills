{
  "name": "darwinian-minds-skills",
  "private": true,
  "version": "0.4.0",
  "description": "Agent skills and mind-card content for operating Darwinian Minds through the drwn CLI.",
  "license": "MIT",
  "files": [
    "bundle.json",
    "skills",
    "cards",
    "examples",
    ".claude-plugin",
    ".codex-plugin",
    "README.md",
    "MAINTAINERS.md",
    "LICENSE",
    "VERSION",
    "scripts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remyjkim/darwinian-minds-skills.git"
  },
  "scripts": {
    "check:identity": "node scripts/check-identity.mjs",
    "check:paths": "node scripts/check-no-local-paths.mjs",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "validate:cards": "node scripts/validate-cards.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "sync:cards": "node scripts/sync-card-skills.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.13.0"
  }
}
